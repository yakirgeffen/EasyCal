PORT=8080
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/easycal?retryWrites=true&w=majority
JWT_SECRET=your_production_jwt_secret_key
SESSION_SECRET=your_production_session_secret_key

# Google OAuth
GOOGLE_CLIENT_ID=your_production_google_client_id
GOOGLE_CLIENT_SECRET=your_production_google_client_secret

# Apple OAuth
APPLE_CLIENT_ID=your_production_apple_client_id
APPLE_TEAM_ID=your_production_apple_team_id
APPLE_KEY_ID=your_production_apple_key_id
APPLE_PRIVATE_KEY_LOCATION=path/to/your/production/private/key.p8

# Microsoft OAuth
MICROSOFT_CLIENT_ID=your_production_microsoft_client_id
MICROSOFT_CLIENT_SECRET=your_production_microsoft_client_secret
